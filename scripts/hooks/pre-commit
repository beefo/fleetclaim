#!/bin/bash
# Pre-commit hook: ensure dist/ is rebuilt when Add-In source changes,
# and type-check any Add-In projects with staged changes.

ADDIN_SRC="src/FleetClaim.AddIn.React/app/"
ADDIN_DIST="src/FleetClaim.AddIn.React/dist/"
DRIVE_SRC="src/FleetClaim.DriveAddIn/app/"

# Get staged files
staged_addin_src=$(git diff --cached --name-only -- "$ADDIN_SRC")
staged_addin_dist=$(git diff --cached --name-only -- "$ADDIN_DIST")
staged_drive_src=$(git diff --cached --name-only -- "$DRIVE_SRC")

# Check Add-In dist/ is rebuilt
if [ -n "$staged_addin_src" ] && [ -z "$staged_addin_dist" ]; then
    echo ""
    echo "ERROR: Add-In source files changed but dist/ was not updated."
    echo ""
    echo "Changed source files:"
    echo "$staged_addin_src" | sed 's/^/  /'
    echo ""
    echo "Run this to rebuild:"
    echo "  cd src/FleetClaim.AddIn.React && NODE_OPTIONS=\"\" npm run build"
    echo "  git add src/FleetClaim.AddIn.React/dist/"
    echo ""
    exit 1
fi

# Type-check Add-In if source changed
if [ -n "$staged_addin_src" ]; then
    echo "Type-checking Add-In..."
    if ! (cd src/FleetClaim.AddIn.React && npx tsc --noEmit 2>&1); then
        echo ""
        echo "ERROR: Add-In TypeScript type-check failed. Fix the errors above before committing."
        echo ""
        exit 1
    fi
fi

# Type-check Drive Add-In if source changed
if [ -n "$staged_drive_src" ]; then
    echo "Type-checking Drive Add-In..."
    if ! (cd src/FleetClaim.DriveAddIn && npx tsc --noEmit 2>&1); then
        echo ""
        echo "ERROR: Drive Add-In TypeScript type-check failed. Fix the errors above before committing."
        echo ""
        exit 1
    fi
fi
